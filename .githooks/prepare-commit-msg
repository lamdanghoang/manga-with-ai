#!/bin/sh
# Strip Cursor co-author trailer from commit messages (local IDE agent).
sed -i '' '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$1" 2>/dev/null \
  || sed -i '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$1"
sed -i '' '/^Made-with: Cursor$/d' "$1" 2>/dev/null \
  || sed -i '/^Made-with: Cursor$/d' "$1"
