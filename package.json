{
  "name": "manga-with-ai",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -w packages/shared && npm run build -w packages/api && npm run build -w packages/web",
    "build:web": "pnpm --filter @manga-with-ai/shared build && pnpm --filter @manga-with-ai/web build",
    "lint": "npm run lint -w packages/api && npm run lint -w packages/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "undici": "^8.3.0"
  }
}
